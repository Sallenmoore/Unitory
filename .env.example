# MongoDB
DB_USERNAME=unitory
DB_PASSWORD=changeme
DB_DB=unitory
DB_HOST=mongo
DB_PORT=27017

# Redis / RQ
REDIS_HOST=redis
REDIS_PORT=6379

# Google OAuth
# Create an OAuth 2.0 Client ID in Google Cloud Console and authorize
# <APP_BASE_URL>/auth/callback as a redirect URI.
GOOGLE_AUTH_CLIENT_ID=
GOOGLE_AUTH_CLIENT_SECRET=
GOOGLE_AUTH_REDIRECT_URL=http://localhost:8000/auth/callback
GOOGLE_DISCOVERY_URL=https://accounts.google.com/.well-known/openid-configuration

# FastAPI session
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET=replace-me-with-a-long-random-string

# Application
APP_BASE_URL=http://localhost:8000
LOG_LEVEL=INFO
NODE_EXPORTER_PORT=9100

# Optional: restrict login to an email allow-list (comma-separated). Leave blank
# to allow any Google account (still requires admin approval for elevated roles).
ALLOWED_EMAIL_DOMAINS=binghamton.edu
